# ──────────────────────────────────────────────
#  NotebookLM MCP Server — Environment Variables
# ──────────────────────────────────────────────

# Browserless.io API token (free tier at https://browserless.io)
BROWSERLESS_TOKEN=your_browserless_token_here

# NotebookLM Google session cookies (base64-encoded JSON)
# Obtain by running: npm run get-cookies
NOTEBOOKLM_STORAGE_STATE=your_base64_encoded_storage_state_here

# Optional: Browserless region (sfo | lon | sea | fra)
BROWSERLESS_REGION=sfo

# Optional: API key to protect your MCP endpoint
# MCP_API_KEY=your_secret_key_here
